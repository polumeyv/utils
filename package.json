{
	"name": "@polumeyv/clients",
	"version": "0.1.5",
	"description": "Effect-based infrastructure clients for Bun applications",
	"license": "MIT",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/polumeyv/clients-lib.git"
	},
	"keywords": ["effect", "bun", "postgres", "redis", "stripe", "ses"],
	"scripts": {
		"release": "npx changelogen --release --push"
	},
	"type": "module",
	"files": ["src"],
	"exports": {
		"./postgres": { "types": "./src/postgres.ts", "default": "./src/postgres.ts" },
		"./redis": { "types": "./src/redis.ts", "default": "./src/redis.ts" },
		"./ses": { "types": "./src/ses.ts", "default": "./src/ses.ts" },
		"./stripe": { "types": "./src/stripe.ts", "default": "./src/stripe.ts" },
		"./error": { "types": "./src/error/index.ts", "default": "./src/error/index.ts" },
		"./rate-limit": { "types": "./src/rate-limit.ts", "default": "./src/rate-limit.ts" }
	},
	"peerDependencies": {
		"effect": "catalog:infra"
	},
	"dependencies": {
		"@aws-sdk/client-sesv2": "catalog:infra",
		"stripe": "catalog:infra"
	}
}
