{
	"name": "@polumeyv/clients",
	"version": "0.1.4",
	"description": "Effect-based infrastructure clients for Bun applications",
	"license": "MIT",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/polumeyv/clients-lib.git"
	},
	"keywords": ["effect", "bun", "postgres", "redis", "stripe", "ses"],
	"scripts": {
		"release": "npx changelogen --release --push"
	},
	"type": "module",
	"files": ["src"],
	"exports": {
		"./redis": { "types": "./src/redis/index.ts", "default": "./src/redis/index.ts" },
		"./postgres": { "types": "./src/postgres/index.ts", "default": "./src/postgres/index.ts" },
		"./stripe": { "types": "./src/stripe/index.ts", "default": "./src/stripe/index.ts" },
		"./ses": { "types": "./src/ses/index.ts", "default": "./src/ses/index.ts" },
		"./error": { "types": "./src/error.ts", "default": "./src/error.ts" }
	},
	"peerDependencies": {
		"effect": "^3.19.0"
	},
	"dependencies": {
		"@aws-sdk/client-sesv2": "^3.978.0",
		"stripe": "^20.2.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.6"
	}
}
