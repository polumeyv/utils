{
  "name": "@polumeyv/lib",
  "version": "0.3.0",
  "description": "Effect-based infrastructure + auth library for Bun applications",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/polumeyv/lib.git"
  },
  "keywords": [
    "effect",
    "bun",
    "postgres",
    "redis",
    "stripe",
    "ses",
    "auth",
    "jwt",
    "otp",
    "passkey",
    "webauthn",
    "oauth"
  ],
  "scripts": {
    "generate-jwt-keys": "bun bin/generate-jwt-keys.mjs",
    "release": "npx changelogen --release --push"
  },
  "bin": {
    "generate-jwt-keys": "./bin/generate-jwt-keys.mjs"
  },
  "type": "module",
  "files": [
    "src",
    "bin"
  ],
  "exports": {
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./server/error": {
      "types": "./src/server/error/index.ts",
      "default": "./src/server/error/index.ts"
    },
    "./public/types": {
      "types": "./src/public/types/index.ts",
      "default": "./src/public/types/index.ts"
    },
    "./public/types/db": {
      "types": "./src/public/types/db/index.ts",
      "default": "./src/public/types/db/index.ts"
    },
    "./public/s3": {
      "types": "./src/public/s3.ts",
      "default": "./src/public/s3.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "default": "./src/auth/index.ts"
    },
    "./auth/server": {
      "types": "./src/auth/server.ts",
      "default": "./src/auth/server.ts"
    },
    "./auth/passkey-client": {
      "types": "./src/auth/passkey/passkey.client.ts",
      "default": "./src/auth/passkey/passkey.client.ts"
    },
    "./auth/oauth2-client": {
      "types": "./src/auth/oauth2/index.ts",
      "default": "./src/auth/oauth2/index.ts"
    }
  },
  "peerDependencies": {
    "effect": "^3.19.19"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1024.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "jose": "^6.2.2",
    "openid-client": "^6.8.3",
    "stripe": "^22.0.0"
  }
}
